{
  "name": "poshshare-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Electron wrapper for Poshshare dashboard",
  "main": "electron-main.js",
  "scripts": {
    "electron": "electron .",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.poshshare.desktop",
    "productName": "Poshshare",
    "asar": true,
    "files": [
      "**/*",
      "!**/.git/**",
      "!**/node_modules/.cache/**"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "jayzo6",
        "repo": "poshshare-desktop"
      }
    ]
  }
}
