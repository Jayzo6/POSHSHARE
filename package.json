{
  "name": "poshshare-desktop",
  "version": "1.0.4",
  "private": true,
  "description": "Electron wrapper for Poshshare dashboard",
  "main": "electron-main.js",
  "scripts": {
    "electron": "electron .",
    "dist": "electron-builder --win nsis",
    "release": "electron-builder --win nsis --publish always"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "build": {
    "appId": "com.poshshare.desktop",
    "productName": "Poshshare",
    "asar": true,
    "compression": "maximum",
    "files": [
      "electron-main.js",
      "preload.js",
      "assets/**/*",
      "package.json",
      "node_modules/**/*",
      "!**/.git/**",
      "!**/.cursor/**",
      "!dist/**",
      "!build/**",
      "!release/**",
      "!out/**",
      "!browsers/**",
      "!bundled_browsers/**",
      "!**/__pycache__/**",
      "!**/*.pyc",
      "!**/*.pyo",
      "!**/*.log",
      "!**/*.md",
      "!**/*.markdown",
      "!**/*.map",
      "!**/node_modules/.cache/**",
      "!**/node_modules/**/{test,tests,__tests__,example,examples}/**"
    ],
    "extraResources": [
      {
        "from": ".",
        "to": "backend",
        "filter": [
          "server.py",
          "dashboard.html",
          "__init__.py",
          "app_paths.py",
          "automation.py",
          "browser_manager.py",
          "captcha_solver.py",
          "login_handler.py",
          "models.py",
          "sharing_logic.py"
        ]
      }
    ],
    "win": {
      "signAndEditExecutable": false,
      "icon": "assets/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "installerIcon": "assets/icon.png",
      "uninstallerIcon": "assets/icon.png",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Jayzo6",
        "repo": "POSHSHARE"
      }
    ]
  }
}
